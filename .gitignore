# Sensitive config - NEVER commit these
config/config.yaml
app/config/config.yaml
storage/settings.json
app/storage/settings.json
storage/settings.json.bak
storage/settings.json.bak2
storage/settings.json.bak.*
storage/settings.json.tmp
app/storage/settings.json.bak
app/storage/settings.json.bak2
app/storage/settings.json.bak.*
app/storage/settings.json.tmp
storage/backups/
storage/weather_history.json
storage/weather_history.json.tmp
app/storage/weather_history.json
app/storage/weather_history.json.tmp

# Identity registries - personal data (face/fur histograms, cat names)
storage/cat_registry.json
storage/person_registry.json
app/storage/cat_registry.json
app/storage/person_registry.json

# Achievements + F09 quest progress - per-install runtime state
storage/achievements.json
app/storage/achievements.json

# F08 bird dossiers - per-install personal field guide
storage/bird_dossiers.json
app/storage/bird_dossiers.json

# F06 first-since records - per-install max-gap memoization
storage/first_since_records.json
app/storage/first_since_records.json

# Logs - may contain RTSP URLs with credentials, IPs, timestamps
storage/logs/
app/storage/logs/
*.log

# Runtime storage - generated data (all binary/media output)
storage/events/
storage/timelapse/
storage/motion_detection/
storage/timelapse_frames/
storage/weather/
storage/.trash/
app/storage/events/
app/storage/timelapse/
app/storage/weather/
app/storage/.trash/
app/storage/

# ML models
models/
app/models/*.tflite
*.tflite

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/

# Environment
.env
.env.*

# Local-dev docker-compose overrides (e.g. to disable Coral USB passthrough
# on hosts without /dev/bus/usb like Windows Docker Desktop).
docker-compose.override.yml

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo

# Lint tooling caches (added in Stage: linter foundation)
.ruff_cache/
.mypy_cache/
.pytest_cache/
node_modules/
package-lock.json

# CSS build artifact — source of truth is app/web/static/css/*.css
# Regenerated at server boot by app/app/css_builder.py
app/web/static/app.css

# Claude internal
.claude/

# Local scratch archives — never the repo's source of truth
*.zip

# Local detection-tuning diagnostics (frames, sweep scripts, reports)
storage/_diag/
