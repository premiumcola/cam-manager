# Sensitive config - NEVER commit these
config/config.yaml
app/config/config.yaml
storage/settings.json
app/storage/settings.json
storage/settings.json.bak
storage/settings.json.bak2
storage/settings.json.bak.*
storage/settings.json.tmp
app/storage/settings.json.bak
app/storage/settings.json.bak2
app/storage/settings.json.bak.*
app/storage/settings.json.tmp
storage/backups/
storage/weather_history.json
storage/weather_history.json.tmp
app/storage/weather_history.json
app/storage/weather_history.json.tmp

# Identity registries - personal data (face/fur histograms, cat names)
storage/cat_registry.json
storage/person_registry.json
app/storage/cat_registry.json
app/storage/person_registry.json

# Logs - may contain RTSP URLs with credentials, IPs, timestamps
storage/logs/
app/storage/logs/
*.log

# Runtime storage - generated data (all binary/media output)
storage/events/
storage/timelapse/
storage/motion_detection/
storage/timelapse_frames/
storage/weather/
app/storage/events/
app/storage/timelapse/
app/storage/weather/
app/storage/

# ML models
models/
app/models/*.tflite
*.tflite

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/

# Environment
.env
.env.*

# Local-dev docker-compose overrides (e.g. to disable Coral USB passthrough
# on hosts without /dev/bus/usb like Windows Docker Desktop).
docker-compose.override.yml

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo

