server:
  host: 0.0.0.0
  port: 8099
  public_base_url: http://DEINE_SERVER_IP:8099
  default_discovery_subnet: 192.168.X.0/24

storage:
  root: /app/storage
  retention_days: 14
  media_limit_default: 24

telegram:
  enabled: false
  token: "DEIN_TELEGRAM_BOT_TOKEN"
  chat_id: "DEINE_TELEGRAM_CHAT_ID"

mqtt:
  enabled: false
  host: homeassistant.local
  port: 1883
  username: "DEIN_MQTT_USERNAME"
  password: "DEIN_MQTT_PASSWORT"
  base_topic: tam-spy

processing:
  event_cooldown_seconds: 25
  # Motion recording: ffmpeg records the RTSP stream directly via stream-copy
  # (no CPU re-encode during capture). A background thread transcodes the raw
  # file to browser-compatible H.264 after the clip ends.
  clip_max_duration_s: 120        # maximum clip length in seconds
  post_motion_tail_s: 3           # seconds of quiet before clip ends
  motion:
    enabled: true
    min_area: 1800
    cooldown_seconds: 25
    blur_size: 21
    # frame_interval_ms only controls how often OpenCV samples a frame for
    # MOTION DETECTION; it no longer affects recorded video quality because
    # ffmpeg captures the RTSP stream independently at the camera's native FPS.
    frame_interval_ms: 350
  detection:
    mode: coral
    model_path: /app/models/coco_ssd_mobilenet_v2_coco_quant_postprocess_edgetpu.tflite
    labels_path: /app/config/coco_labels.example.txt
    min_score: 0.55
    device: usb
  bird_species:
    enabled: false
    model_path: /app/models/inat_bird_quant_edgetpu.tflite
    cpu_model_path: /app/models/inat_bird_quant.tflite
    labels_path: /app/models/inat_bird_labels.txt
    latin_to_de_path: /app/config/inat_to_german.json
    min_score: 0.25
    device: usb
  # Wildlife classifier (ImageNet MobileNet V2 → fox / squirrel / hedgehog).
  # Used as a second-stage when COCO can't name the animal — the three
  # target species are outside COCO's 80-class vocabulary.
  wildlife:
    enabled: false
    model_path: /app/models/mobilenet_v2_1.0_224_quant_edgetpu.tflite
    cpu_model_path: /app/models/mobilenet_v2_1.0_224_quant.tflite
    labels_path: /app/models/imagenet_labels.txt
    min_score: 0.35
    device: usb
  cat_identity:
    match_threshold: 10
  person_identity:
    match_threshold: 10

cameras:
  - id: cam-beispiel-1
    name: Beispielkamera 1
    location: Beschreibung des Standorts
    enabled: true
    rtsp_url: rtsp://KAMERA_BENUTZER:KAMERA_PASSWORT@KAMERA_IP:554/h264Preview_01_main
    snapshot_url: ""
    username: KAMERA_BENUTZER
    password: KAMERA_PASSWORT
    object_filter: [bird, cat, person]
    armed: true
    telegram_enabled: true
    mqtt_enabled: true
    whitelist_names: []
    schedule: { enabled: false, start: "22:00", end: "06:00" }
    # New per-camera detection / alarm settings (all have sensible defaults):
    alarm_profile: info            # hard | medium | soft | info
    motion_enabled: true
    detection_trigger: motion_and_objects   # motion_and_objects | objects_only | motion_only
    post_motion_tail_s: 0          # 0 = inherit global default
    timelapse:
      enabled: true
      fps: 25

  - id: cam-beispiel-2
    name: Beispielkamera 2
    location: Beschreibung des Standorts
    enabled: true
    rtsp_url: rtsp://KAMERA_BENUTZER:KAMERA_PASSWORT@KAMERA_IP:554/Streaming/Channels/101
    snapshot_url: ""
    username: KAMERA_BENUTZER
    password: KAMERA_PASSWORT
    object_filter: [person, cat, car]
    armed: true
    telegram_enabled: true
    mqtt_enabled: true
    whitelist_names: []
    schedule: { enabled: true, start: "22:00", end: "06:00" }
    timelapse:
      enabled: false
      fps: 25
